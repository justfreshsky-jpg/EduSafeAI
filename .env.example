# Copy this file to .env and fill in your values. Never commit .env.

# Port for the Flask server (optional, defaults to 5000)
PORT=5000

# ── Tier 1: Primary providers (fastest, highest quality) ─────
GROQ_KEY=your_groq_api_key_here
CEREBRAS_KEY=your_cerebras_api_key_here
GEMINI_KEY=your_gemini_api_key_here

# ── Tier 2: Backup providers ──────────────────────────────────
COHERE_KEY=your_cohere_api_key_here
MISTRAL_KEY=your_mistral_api_key_here
OPENROUTER_KEY=your_openrouter_api_key_here

# ── Tier 3: Emergency fallback providers ──────────────────────
HF_KEY=your_huggingface_token_here

# ── Reserved for future provider support ──────────────────────
CF_ACCOUNT_ID=your_cloudflare_account_id_here
CF_KEY=your_cloudflare_api_token_here
NEBIUS_KEY=your_nebius_api_key_here
